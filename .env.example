# Copy this file to .env and fill in your actual values.
# Never commit the real .env file — it's already listed in .gitignore.

# Azure Event Hub connection string (from: Event Hub Namespace -> Shared access policies -> RootManageSharedAccessKey)
EVENTHUB_CONNECTION_STR=Endpoint=sb://<your-namespace>.servicebus.windows.net/;SharedAccessKeyName=<key-name>;SharedAccessKey=<key-value>

# Name of the specific Event Hub (not the namespace) you created
EVENTHUB_NAME=crypto-trades
